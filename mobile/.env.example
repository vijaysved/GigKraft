# GigKraft mobile env template. Copy to .env; never commit real secrets.
# Expo exposes only EXPO_PUBLIC_-prefixed vars to the app bundle.

# Use your machine's LAN IP instead of localhost when testing on a device.
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# Phase 1 mocks (flip in Phase 2 when integrations go live)
EXPO_PUBLIC_MOCK_OTP=true
EXPO_PUBLIC_MOCK_PUSH=true
EXPO_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=
