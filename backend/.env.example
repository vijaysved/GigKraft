# GigKraft backend env template. Copy to .env; never commit real secrets.

# --- Core ---
DEBUG=true
SECRET_KEY=change-me-in-local-only
ALLOWED_HOSTS=localhost,127.0.0.1,10.0.2.2
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Database / cache (matches root docker-compose defaults) ---
DATABASE_URL=postgresql://gigkraft:gigkraft@localhost:5432/gigkraft
REDIS_URL=redis://localhost:6379/0

# --- JWT ---
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=14

# --- Integration mocks (flip to false when wiring live services) ---
# Deterministic OTP code used while MOCK_TWILIO=true (never used live).
MOCK_OTP_CODE=123456
MOCK_TWILIO=true
MOCK_STRIPE=true
MOCK_S3=true
MOCK_FCM=true
MOCK_WHATSAPP=true

# --- Google OAuth ---
# Create at https://console.cloud.google.com/ → APIs & Services → Credentials
# OAuth 2.0 Client ID (Web application)
# Authorized JavaScript origins: http://localhost:5173 (dev), https://gigkraft.com (prod)
GOOGLE_CLIENT_ID=

# --- Other credentials (leave blank while mocked) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
FCM_CREDENTIALS_JSON=
