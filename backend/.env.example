# GigKraft backend env template. Copy to .env and fill in values.
# Never commit .env — it's gitignored.
#
# How dev vs prod works:
#   Local dev  → values come from this file (backend/.env)
#   Production → same env var names, set directly in Railway (never a .env file)

# --- Core ---
DJANGO_SECRET_KEY=change-me-in-local-only
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,10.0.2.2
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Database ---
DATABASE_URL=postgresql://gigkraft:gigkraft@localhost:5432/gigkraft

# --- JWT ---
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=14

# --- Integration mock flags (true in dev, false in prod) ---
MOCK_TWILIO=true
MOCK_STRIPE=true
MOCK_S3=true
MOCK_FCM=true
MOCK_WHATSAPP=true
MOCK_RESEND=true
MOCK_OTP_CODE=123456

# --- Google OAuth ---
# Dev client:  authorized JS origin = http://localhost:5173
# Prod client: authorized JS origin = https://gigkraft.com  (set in Railway, not here)
# Get from https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=<your-dev-client-id>

# --- Resend (email) ---
# Dev:  MOCK_RESEND=true skips sending; DEV_EMAIL_TO redirects all mail to one address
# Prod: MOCK_RESEND=false + real API key
RESEND_API_KEY=
DEV_EMAIL_TO=

# --- Stripe ---
# STRIPE_MODE controls which key is used: "test" locally, "live" in prod.
# Dev:  STRIPE_MODE=test + STRIPE_TEST_SECRET_KEY (from Stripe test dashboard)
# Prod: STRIPE_MODE=live + STRIPE_SECRET_KEY (from Stripe live dashboard)
STRIPE_MODE=test
STRIPE_TEST_SECRET_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Twilio (SMS / OTP) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# --- AWS S3 ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# --- Firebase (push notifications) ---
FCM_CREDENTIALS_JSON=
