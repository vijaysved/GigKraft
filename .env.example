# GigKraft shared infrastructure env (consumed by docker-compose.yml).
# Copy to .env and adjust as needed. Never commit real secrets.

# --- PostgreSQL ---
POSTGRES_DB=gigkraft
POSTGRES_USER=gigkraft
POSTGRES_PASSWORD=gigkraft
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Global flags ---
# Phase 1: all third-party integrations (Twilio, Stripe, S3, FCM, Google OAuth)
# are mocked. Flip per-service flags in each app's .env when going live (Phase 2).
ENVIRONMENT=local
