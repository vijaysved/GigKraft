{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://gigkraft-backend-production.up.railway.app/api/:path*"
    },
    {
      "source": "/go/:path*",
      "destination": "https://gigkraft-backend-production.up.railway.app/go/:path*"
    },
    {
      "source": "/r/:code",
      "destination": "https://gigkraft-backend-production.up.railway.app/r/:code"
    },
    {
      "source": "/us/:slug/refer",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(facebookexternalhit|whatsapp|telegrambot|twitterbot|linkedinbot|slackbot|discordbot|googlebot|bingbot|applebot|ia_archiver|redditbot|pinterest).*"
        }
      ],
      "destination": "https://gigkraft-backend-production.up.railway.app/us/:slug/refer"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
