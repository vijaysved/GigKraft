# GigKraft frontend env template. Copy to .env; never commit real secrets.
# Vite exposes only VITE_-prefixed vars to the client bundle.

VITE_API_BASE_URL=http://localhost:8000

# Phase 1: Google sign-in is mocked end to end; the client ID stays blank.
VITE_GOOGLE_OAUTH_CLIENT_ID=
VITE_MOCK_GOOGLE_OAUTH=true
