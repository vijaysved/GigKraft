# GigKraft frontend env template. Copy to .env; never commit real secrets.
# Vite exposes only VITE_-prefixed vars to the client bundle.

VITE_API_BASE_URL=http://localhost:8000

# Google OAuth — must match the client ID in backend/.env
# Same client ID from https://console.cloud.google.com/
VITE_GOOGLE_CLIENT_ID=
